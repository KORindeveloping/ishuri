{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "dev:backend": "npm run dev --prefix backend",
    "dev:full": "npx concurrently \"npm run dev\" \"npm run dev --prefix backend\"",
    "install:all": "npm install && npm install --prefix backend",
    "build": "npx vite build",
    "preview": "npx vite preview",
    "clean": "npx rimraf dist",
    "lint": "tsc --noEmit",
    "build:gh-pages": "npx vite build",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@google/generative-ai": "^0.24.1",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "framer-motion": "^12.38.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.14",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "gh-pages": "^6.3.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  },
  "overrides": {
    "fetch-blob": "^4.0.0"
  }
}